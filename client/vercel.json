{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://portfolio-production-453a.up.railway.app/api/:path*"
    },
    {
      "source": "/resume.pdf",
      "destination": "/resume.pdf"
    },
    {
      "source": "/((?!api|resume.pdf).*)",
      "destination": "/index.html"
    }
  ]
}
